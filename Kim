<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Henry's Golden Time</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/matter-js/0.19.0/matter.min.js"></script>
    <style>
        body { 
            margin: 0; padding: 0; width: 100vw; height: 100vh; 
            background: #1a1a2e url('https://i.redd.it/8nk7y935nr1a1.jpg') no-repeat center center / cover; 
            overflow: hidden; touch-action: none; font-family: sans-serif;
        }
        
        #scoreboard-wrapper { position: absolute; top: 15px; left: 50%; transform: translateX(-50%); z-index: 30; text-align: center; width: 100%; }
        
        #title {
            font-weight: 900; font-size: 26px; color: #f1c40f;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
            margin-bottom: 5px; text-transform: uppercase;
        }

        #scoreboard { background: rgba(255,255,255,0.9); border: 3px solid #1a1a2e; border-radius: 10px; padding: 5px 15px; font-weight: 900; font-size: 16px; color: #1a1a2e; display: inline-block; }
        #score-value { color: #f1c40f; font-size: 22px; }
        
        /* Controls placed clearly below the scoreboard */
        #controls { position: absolute; top: 110px; left: 50%; transform: translateX(-50%); display: flex; gap: 6px; z-index: 20; opacity: 0; pointer-events: none; transition: 0.3s; }
        #controls.visible { opacity: 1; pointer-events: auto; }
        #controls button { padding: 10px 12px; font-weight: 700; font-size: 13px; border: 2px solid #1a1a2e; border-radius: 8px; cursor: pointer; }
        
        #reset-btn { 
            position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); 
            background: #34495e; color: #fff; font-weight: 700; font-size: 13px; padding: 8px 16px; border: 2px solid #1a1a2e; border-radius: 8px; z-index: 20;
        } 

        #tube-container { position: absolute; bottom: 70px; left: 50%; transform: translateX(-50%); width: 180px; height: 400px; z-index: 10; pointer-events: none; }
        #glass-tube { width: 100%; height: 100%; border: 4px solid rgba(255, 255, 255, 0.5); border-top: none; border-radius: 0 0 15px 15px; background: rgba(255, 255, 255, 0.05); }
    </style>
</head>
<body>

    <div id="scoreboard-wrapper">
        <div id="title">Henry's Golden Time</div>
        <div id="scoreboard">TOTAL: <span id="score-value">0</span> minutes</div>
    </div>
    
    <div id="controls">
        <button id="ring-btn" style="background:#9b59b6; color:#fff;">(+1) Ring</button>
        <button id="gem-btn" style="background:#f1c40f; color:#1a1a2e;">💎 (+3)</button>
        <button id="remove-btn" style="background:#e74c3c; color:#fff;">➖ Lose</button>
    </div>

    <button id="reset-btn">🔄 Reset</button>
    
    <div id="tube-container"><div id="glass-tube"></div></div>

    <script>
        const { Engine, Render, Runner, Bodies, Composite } = Matter;
        const engine = Engine.create();
        const world = engine.world;
        let totalScore = 0, tokens = [];
        
        const render = Render.create({ element: document.body, engine, options: { width: window.innerWidth, height: window.innerHeight, wireframes: false, background: 'transparent' } });
        Render.run(render); Runner.run(Runner.create(), engine);

        const centerX = window.innerWidth / 2;
        const tubeBottom = window.innerHeight - 70;
        const dropY = tubeBottom - 350; 
        
        Composite.add(world, [
            Bodies.rectangle(centerX, tubeBottom + 20, 180, 40, { isStatic: true, render: { visible: false } }),
            Bodies.rectangle(centerX - 90, tubeBottom - 200, 10, 400, { isStatic: true, render: { visible: false } }),
            Bodies.rectangle(centerX + 90, tubeBottom - 200, 10, 400, { isStatic: true, render: { visible: false } })
        ]);

        const addRing = () => {
            const dropX = centerX + (Math.random() * 20 - 10);
            const ring = Bodies.circle(dropX, dropY, 30, { restitution: 0.5, render: { fillStyle: 'transparent', strokeStyle: '#f1c40f', lineWidth: 8 } });
            tokens.push({ body: ring, type: 'ring', value: 1 });
            totalScore += 1; document.getElementById('score-value').innerText = totalScore; Composite.add(world, ring);
        };

        const addGem = () => {
            const dropX = centerX + (Math.random() * 20 - 10);
            const gem = Bodies.polygon(dropX, dropY, 6, 40, { 
                restitution: 0.3, friction: 0.1, 
                render: { sprite: { texture: 'https://cdn-icons-png.flaticon.com/512/408/408472.png', xScale: 0.16, yScale: 0.16 } }
            });
            Matter.Body.setAngularVelocity(gem, (Math.random() - 0.5) * 0.4);
            tokens.push({ body: gem, type: 'gem', value: 3 });
            totalScore += 3; document.getElementById('score-value').innerText = totalScore; Composite.add(world, gem);
        };

        document.getElementById('ring-btn').addEventListener('pointerdown', addRing);
        document.getElementById('gem-btn').addEventListener('pointerdown', addGem);
        document.getElementById('remove-btn').addEventListener('pointerdown', () => {
            const idx = tokens.map(t => t.type).lastIndexOf('ring');
            if (idx > -1) {
                totalScore -= tokens[idx].value; document.getElementById('score-value').innerText = totalScore; Composite.remove(world, tokens[idx].body); tokens.splice(idx, 1);
            }
        });

        document.getElementById('reset-btn').addEventListener('pointerdown', () => {
            tokens.forEach(t => Composite.remove(world, t.body));
            tokens = []; totalScore = 0; document.getElementById('score-value').innerText = totalScore;
            for (let i = 0; i < 5; i++) { setTimeout(addRing, i * 150); }
        });

        let lastTap = 0;
        document.getElementById('scoreboard-wrapper').addEventListener('pointerdown', () => {
            const now = new Date().getTime();
            if (now - lastTap < 400) document.getElementById('controls').classList.toggle('visible');
            lastTap = now;
        });
    </script>
</body>
</html>
